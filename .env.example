# annotator configuration
# All variables are prefixed with ANNOTATOR_

# kombinat API URL
# ANNOTATOR_KOMBINAT_URL=https://api.embedkombinat.dev

# GitHub OAuth App client ID
# ANNOTATOR_GITHUB_CLIENT_ID=Ov23li...

# Batch size (pairs per batch claimed from kombinat)
# ANNOTATOR_BATCH_SIZE=100

# Chunk size (pairs per submission to kombinat)
# ANNOTATOR_CHUNK_SIZE=50

# Fraction of GPU memory for inference (vLLM only)
# ANNOTATOR_GPU_MEMORY_UTILIZATION=0.9

# Max model context length
# ANNOTATOR_MAX_MODEL_LEN=4096

# Max output tokens per response
# ANNOTATOR_MAX_OUTPUT_TOKENS=256

# Annotator home directory (auth, models, logs)
# ANNOTATOR_ANNOTATOR_HOME=~/.annotator
